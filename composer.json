{
    "name": "hovakimyannn/omnipay-epg",
    "type": "library",
    "description": "SmartVista EPG (E-Commerce Payment Gateway) driver for Omnipay. Supports Arca, and any other EPG-based bank.",
    "keywords": [
        "gateway",
        "merchant",
        "omnipay",
        "pay",
        "payment",
        "epg",
        "smartvista",
        "arca",
        "ipay"
    ],
    "homepage": "https://github.com/hovakimyannn/omnipay-epg",
    "license": "MIT",
    "authors": [
        {
            "name": "Poghos Boyajyan",
            "email": "poghosboyajyan@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Omnipay\\Epg\\": "src/"
        }
    },
    "require": {
        "omnipay/common": "^3",
        "ext-json": "*",
        "php": "^7.2|8.*",
        "symfony/http-client": "^7.4"
    },
    "require-dev": {
        "omnipay/tests": "^v4.0.0"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "3.0.x-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
